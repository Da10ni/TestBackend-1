# Copy to .env and adjust. The app validates these at boot and refuses to
# start if any required value is missing or too short.

NODE_ENV=development
PORT=3000

# Postgres connection. The host "postgres" matches the docker compose service.
# For running the app on your host (outside docker) use localhost:5432.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/wallet?schema=public

# Shared secret the fake payment provider uses to HMAC-sign webhooks.
# Generate a real one with: openssl rand -hex 32
WEBHOOK_SECRET=dev_webhook_secret_change_me_min16

# Secret used to sign user JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=dev_jwt_secret_change_me_min16chars
JWT_EXPIRES_IN=15m

# Max allowed drift (seconds) between a webhook's X-Timestamp and server time.
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
